# .gitignore

# Node
node_modules/
dist/
.next/
.turbo/
.pnpm-store/
.venv/

# Python
__pycache__/
*.py[cod]
.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/

# Environment
.env
.env.local
.env.*.local

# Docker volumes (never commit data dirs)
data/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build artifacts
*.tsbuildinfo

# Project-specific
# Note: Buildplan.md is intentionally tracked (force-added) despite being in gitignore previously.
# It is now tracked. Only devstudy.md is excluded.

services/ai-worker/build
services/ai-worker/.venv
services/hash-worker/build
services/hash-worker/.venv

# Developer study notes (personal reference — not for committing)
devstudy.md